# Integration test image: PostgreSQL 16 + Apache AGE 1.5.0 + pgvector 0.7.4
#
# Single-stage build: install pgvector from source tarball into the AGE
# image (which is based on postgres:16 with AGE pre-installed).
#
# TLS: The image bundles pg_hba.conf requiring client certificates for TCP
# connections. SSL certs are mounted at runtime from .test-output/certs/.

FROM docker.io/apache/age:release_PG16_1.5.0

USER root

SHELL ["/bin/bash", "-o", "pipefail", "-c"]

# Reason: base image (apache/age) tracks Debian point releases; pinning
# build-time-only packages to exact versions adds maintenance burden with
# no security benefit since they are purged in the same layer.
# hadolint ignore=DL3008
RUN apt-get update && \
    apt-get install -y --no-install-recommends \
        build-essential \
        ca-certificates \
        curl \
        postgresql-server-dev-16 && \
    curl -sL https://github.com/pgvector/pgvector/archive/refs/tags/v0.7.4.tar.gz \
        | tar xz -C /tmp && \
    rm -rf /var/lib/apt/lists/*

WORKDIR /tmp/pgvector-0.7.4

RUN make && make install && \
    apt-get purge -y build-essential curl postgresql-server-dev-16 && \
    apt-get autoremove -y && \
    rm -rf /tmp/pgvector-0.7.4

WORKDIR /

RUN echo "CREATE EXTENSION IF NOT EXISTS age CASCADE;" > /docker-entrypoint-initdb.d/01-age.sql && \
    echo "CREATE EXTENSION IF NOT EXISTS vector;" > /docker-entrypoint-initdb.d/02-vector.sql

# Copy mTLS-enforcing pg_hba.conf into the image.
# SSL cert/key paths are passed at runtime via CMD overrides.
COPY pg_hba.conf /etc/postgresql/pg_hba.conf

USER postgres

HEALTHCHECK --interval=5s --timeout=3s --retries=3 \
    CMD ["pg_isready"]

CMD ["postgres", "-c", "shared_preload_libraries=age", "-c", "hba_file=/etc/postgresql/pg_hba.conf"]
